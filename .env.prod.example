# --- Прод-окружение для docker-compose.prod.yml. Скопировать в .env и заполнить. ---
# Секреты сюда НЕ коммитить: .env в .gitignore.

APP_ENV=prod
DEBUG=false

# --- Домен и HTTPS (Caddy) ---
# Нет своего домена -> sslip.io по IP сервера: <IP-через-дефисы>.sslip.io
# (напр. 139-100-202-3.sslip.io). Let's Encrypt выдаст сертификат автоматически.
DOMAIN=CHANGE-ME.sslip.io
ACME_EMAIL=badrutdinov.ernest@gmail.com

# --- Telegram ---
BOT_TOKEN=CHANGE-ME
BOT_USERNAME=AI_PRO_RU_BOT
BOT_MODE=polling
# ADMIN_IDS: telegram-id админов через запятую (доступ к /admin).
ADMIN_IDS=CHANGE-ME

# --- URL'ы (тот же домен: фронт и API через Caddy) ---
FRONTEND_URL=https://${DOMAIN}
BACKEND_PUBLIC_URL=https://${DOMAIN}
WEBAPP_URL=https://${DOMAIN}
# Имя для кнопки поддержки (инлайнится в фронт при сборке).
SUPPORT_USERNAME=Ernest99

# --- База и Redis (внутри compose-сети) ---
POSTGRES_DB=ai_bot
POSTGRES_USER=ai_bot
POSTGRES_PASSWORD=CHANGE-ME-STRONG
DATABASE_URL=postgresql+asyncpg://ai_bot:CHANGE-ME-STRONG@postgres:5432/ai_bot
REDIS_URL=redis://redis:6379/0

# --- fal (медиа + текст через LLM router). Ключи вводит владелец. ---
FAL_IMAGE_KEY=CHANGE-ME
FAL_VIDEO_KEY=CHANGE-ME
# Текст: отдельный ключ для раздельного учёта; можно тот же, что IMAGE.
FAL_TEXT_KEY=CHANGE-ME
# Секрет fal-вебхука: без него /webhooks/fal отвечает 403 и генерация виснет.
FAL_WEBHOOK_SECRET=CHANGE-ME-RANDOM

# --- ЮKassa (опционально; без ключей работают только Telegram Stars) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PAYMENT_RETURN_URL=https://${DOMAIN}/payment/return
