# Caddy: авто-HTTPS (Let's Encrypt) + reverse-proxy на едином домене.
# DOMAIN и ACME_EMAIL приходят из окружения (docker-compose.prod.yml).
#
# Пути backend'а идут на backend:8000, всё остальное -- на фронт (Next.js).
# Single-origin: фронт бьёт /api относительно, отдельного CORS не требуется.

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip

	# --- Кеш статических медиа. header_down ПЕРЕЗАПИСЫВАЕТ Cache-Control из
	# ответа upstream (Next.js по умолчанию ставит max-age=0), поэтому обычный
	# `header` тут не сработал бы -- нужен header_down внутри reverse_proxy.
	# 30 дней для контент-ассетов (баннеры/тренды/карточки/логотипы; при смене
	# баннера из админки идёт новый файл). Загрузки /uploads по uuid-имени --
	# immutable на год. ---
	@uploads path /uploads/*
	handle @uploads {
		# backend отдаёт загрузки статикой (StaticFiles); без этого правила ушли бы на фронт (404).
		reverse_proxy backend:8000 {
			header_down Cache-Control "public, max-age=31536000, immutable"
		}
	}

	@media path /banners/* /trends/* /actions/* /models/* /structural/*
	handle @media {
		reverse_proxy frontend:3000 {
			header_down Cache-Control "public, max-age=2592000, stale-while-revalidate=86400"
		}
	}

	# --- API и серверные пути -> backend ---
	@backend path /api/* /webhooks/* /webhook/* /health /payment/* /docs* /redoc* /openapi.json /actuator/*
	handle @backend {
		reverse_proxy backend:8000
	}

	# --- всё остальное -> фронт (Next.js) ---
	handle {
		reverse_proxy frontend:3000
	}
}
