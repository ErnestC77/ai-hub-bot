BOT_TOKEN=

BOT_MODE=polling
WEBAPP_URL=http://localhost:8000
WEBHOOK_SECRET=
BOT_USERNAME=

# Used both as the Telegram menu-button URL and as CORS allow_origins
# (app/main.py) -- without it, allow_origins is empty and the backend
# rejects every cross-origin fetch, including frontend-next's local
# Playwright e2e runs against this docker-compose backend on :8000.
# Set to http://localhost:3000 for local dev/e2e.
FRONTEND_URL=

APP_ENV=dev

DATABASE_URL=postgresql+asyncpg://ai_bot:strong_password@postgres:5432/ai_bot
REDIS_URL=redis://redis:6379/0

# --- AI provider keys ---
# Приложение использует ТОЛЬКО fal (медиа) + OpenRouter (текст).

# fal.ai
FAL_IMAGE_KEY=
FAL_VIDEO_KEY=
FAL_DEV_KEY=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_FALLBACK_KEY=
OPENROUTER_DEV_KEY=

# fal.ai webhook: секрет сверяется в POST /api/fal/webhook?secret=...
FAL_WEBHOOK_SECRET=

# Публичный https-URL этого бэкенда -- из него собирается fal webhook-callback
# (на Render задаётся вручную, см. render.yaml)
BACKEND_PUBLIC_URL=

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

PAYMENT_RETURN_URL=https://your-domain.ru/payment/return

ADMIN_IDS=123456789,987654321
